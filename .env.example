# Copy file này thành ".env" rồi điền API key thật trước khi chạy docker-compose.
# KHÔNG commit file .env thật lên Git (đã có trong .gitignore).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── VNPT AI (SmartReader) — "động cơ kép", TÙY CHỌN ─────────────────────
# Nếu để trống, hệ thống tự động dùng Claude Vision như trước (không lỗi,
# không cần cấu hình gì thêm) — xem vnpt_client.py và main.py để biết logic
# fallback. Chỉ cần điền nếu muốn ưu tiên SmartReader làm OCR chính.
VNPT_TOKEN_ID=
VNPT_TOKEN_KEY=
VNPT_ACCESS_TOKEN=
# mac-address: xuất hiện trong Postman collection thật của BTC nhưng chưa
# rõ có bắt buộc hay không — để trống dùng giá trị mặc định 00:00:00:00:00:00
VNPT_MAC_ADDRESS=
# Domain mặc định https://api.idg.vnpt.vn nếu để trống
VNPT_API_DOMAIN=

# ─── VNPT Smartbot FAQ (module hỗ trợ, ĐỘC LẬP với MedAmi lâm sàng) ───────
# Endpoint đã xác thực (assistant-stream.vnpt.vn/v1/conversation), dùng
# chung VNPT_TOKEN_ID/VNPT_TOKEN_KEY/VNPT_ACCESS_TOKEN ở trên. Chỉ còn thiếu
# bot_id — PHẢI tạo bot trên console-smartbot.vnpt.vn trước (xem
# Hướng_dẫn_khởi_tạo_kịch_bản.pptx), rồi điền vào đây. Để trống -> widget
# FAQ tự hiện "đang bảo trì", KHÔNG lỗi, KHÔNG crash.
VNPT_FAQ_BOT_ID=

# ─── VNPT Smartbot lâm sàng (chat_smartbot — dùng cho /chat MedAmi) ───────
# CỐ Ý CHƯA DÙNG ĐƯỢC — quyết định kiến trúc: Smartbot dạng kịch bản/FAQ
# không phù hợp làm lõi suy luận lâm sàng động trên hồ sơ bệnh nhân (xem
# phân tích chi tiết trong lịch sử trao đổi). /chat vẫn dùng Claude, không
# cần biến môi trường nào ở đây.

# ─── VNPT SmartVoice (TTS/STT) — ĐANG CHỜ TÀI LIỆU BTC ────────────────────
# Tài liệu hiện có chỉ chứa token, chưa có endpoint/format request-response.
# Đặt biến môi trường ở đây chưa có tác dụng cho tới khi vnpt_client.py
# text_to_speech()/speech_to_text() được cập nhật với spec thật. Trong lúc
# chờ, /voice/tts và /voice/stt tự trả fallback an toàn (use_local_tts,
# STT_FALLBACK), Frontend tự chuyển sang Web Speech API của trình duyệt.
